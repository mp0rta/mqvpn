// Copy to Config.xcconfig and fill in. Config.xcconfig is gitignored.
DEVELOPMENT_TEAM = YOUR_TEAM_ID
// PoC server (hostname or IPv4 literal; resolved once at tunnel start)
MQVPN_POC_SERVER_HOST = 192.0.2.1
MQVPN_POC_SERVER_PORT = 4433
// TLS SNI / cert verify name (empty = use SERVER_HOST), like client.conf ServerName
MQVPN_POC_SERVER_NAME =
// Auth key matching the test-server config (empty = no Authorization header)
MQVPN_POC_AUTH_KEY = changeme
// 1 = skip TLS certificate verification (test-server only)
MQVPN_POC_TLS_INSECURE = 1
// HTTP URL fetched through the tunnel for the multipath load gate.
// NOTE: "//" starts a comment ANYWHERE on an xcconfig line — URLs must
// break it with an empty substitution, or the value truncates to "http:".
MQVPN_POC_BULK_URL = http:/$()/192.0.2.1:8080/bulk-100M.bin
