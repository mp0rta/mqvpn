# mqvpn client configuration
# Copy to /etc/mqvpn/client-<name>.conf and edit as needed.
# Start with: systemctl start mqvpn-client@<name>

[Server]
Address = your-server.example.com:443
# Insecure = false

[Auth]
Key = <YOUR_PSK_HERE>

[Interface]
TunName = mqvpn0
DNS = 1.1.1.1, 8.8.8.8
LogLevel = info
# MTU = 1280                   # TUN MTU (1280–9000, default: auto = ~1382)
# KillSwitch = false
# ManageRoutes = true            # set to false on router/embedded integrations to keep host routes untouched
# Reconnect = true
# ReconnectInterval = 5

[Multipath]
Scheduler = wlb
# CC = bbr2                     # Congestion control (bbr2|bbr|cubic|none)
# Path = eth0
# Path = wlan0
