# mqvpn client configuration (Windows)
# Place this file alongside mqvpn.exe (or pass via --config <path>) and edit as needed.

[Server]
Address = your-server.example.com:443
# Insecure = false

[Auth]
Key = <YOUR_PSK_HERE>

[Interface]
TunName = mqvpn0
DNS = 1.1.1.1, 8.8.8.8
LogLevel = info
# KillSwitch = false
# Reconnect = true
# ReconnectInterval = 5

[Multipath]
Scheduler = wlb
# Path = Ethernet
# Path = Wi-Fi
